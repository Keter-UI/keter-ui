{
  "name": "@keter-ui/core",
  "version": "1.0.1",
  "private": false,
  "description": "Core utilities for Keter UI — cn(), variant system, shared types",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "tailwind-merge": "^3.5.0"
  },
  "peerDependencies": {
    "react": ">=18"
  },
  "devDependencies": {
    "@types/react": "^18.0.0",
    "react": "^18.0.0",
    "rimraf": "^5.0.10",
    "tsup": "^8.3.5",
    "typescript": "~5.8.2"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/keter-ui/keter-ui"
  },
  "keywords": [
    "react",
    "ui",
    "design-system",
    "tailwind",
    "components",
    "keter-ui"
  ],
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  }
}
