{
  "name": "@keter-ui/cli",
  "version": "1.0.13",
  "private": false,
  "description": "CLI for Keter UI — scaffold components, setup tokens, initialize projects",
  "license": "MIT",
  "type": "commonjs",
  "bin": {
    "keter-ui": "dist/index.js"
  },
  "main": "dist/index.js",
  "files": [
    "dist",
    "registry"
  ],
  "scripts": {
    "build": "npm run sync-registry && tsup",
    "postbuild": "npm run validate",
    "sync-registry": "rimraf registry && cp -r ../../registry .",
    "validate": "node -e \"const fs=require('fs'); const content=fs.readFileSync('dist/index.js', 'utf8'); if (!content.startsWith('#!/usr/bin/env node')) { console.error('Error: Missing shebang in dist/index.js'); process.exit(1); }\"",
    "test:cli": "node dist/index.js --help",
    "publish:safe": "npm run build && npm run test:cli && npm publish --access public",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "chalk": "^5.4.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "commander": "^12.1.0",
    "execa": "^9.5.2",
    "fs-extra": "^11.2.0",
    "ora": "^8.2.0",
    "picocolors": "^1.1.1",
    "prompts": "^2.4.2",
    "react-hook-form": "^7.75.0",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^22.14.0",
    "@types/prompts": "^2.4.9",
    "rimraf": "^5.0.10",
    "tsup": "^8.5.1",
    "typescript": "~5.8.2"
  }
}
