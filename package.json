{
  "name": "keter-ui",
  "version": "0.0.0",
  "private": true,
  "description": "AI-first, RTL-first production UI system",
  "repository": {
    "type": "git",
    "url": "https://github.com/keter-ui/keter-ui"
  },
  "scripts": {
    "build": "npm run build:cli",
    "build:cli": "cd packages/cli && npm run build",
    "dev": "node packages/cli/dist/index.js",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "clean": "turbo run clean && rimraf node_modules",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md,css}\" --ignore-path .gitignore",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "turbo run build && changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.9",
    "@types/node": "^22.14.0",
    "prettier": "^3.4.2",
    "rimraf": "^5.0.10",
    "turbo": "^2.3.3",
    "typescript": "~5.8.2"
  },
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.15.4"
}
